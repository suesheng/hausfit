---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "./Breadcrumb.astro";
import RelatedServices from "./RelatedServices.astro";
import ServiceSchema from "./ServiceSchema.astro";
import { einsatzgebietCityLinks } from "../data/cities.js";
import { getServicePageMeta } from "../data/page-meta.js";

interface Props {
  metaSlug: string;
  serviceName: string;
  serviceSlug: string;
  description: string;
  h1: string;
  intro: string;
  services: string[];
  forWhom?: string[];
  advantages: string[];
  process: string[];
  ctaTitle?: string;
  ctaText?: string;
}

const {
  metaSlug,
  serviceName,
  serviceSlug,
  description,
  h1,
  intro,
  services,
  forWhom = ["Eigentümer", "Vermieter", "Hausverwaltungen"],
  advantages,
  process,
  ctaTitle = "Jetzt Angebot anfordern",
  ctaText = "Beschreiben Sie Ihr Projekt in kurzen Stichpunkten. Wir melden uns zeitnah zurück."
} = Astro.props;

const pageMeta = getServicePageMeta(metaSlug);
if (!pageMeta) {
  throw new Error(`Service page meta not found for slug: ${metaSlug}`);
}

---

<BaseLayout title={pageMeta.title} description={pageMeta.description}>
  <ServiceSchema
    slot="head"
    serviceName={serviceName}
    serviceSlug={serviceSlug}
    description={description}
  />
  <section class="page-hero">
    <div class="container">
      <Breadcrumb
        items={[
          { label: "Startseite", url: "/" },
          { label: "Leistungen", url: "/leistungen" },
          { label: serviceName, url: `/leistungen/${metaSlug}` }
        ]}
      />
      <p class="eyebrow">Leistung</p>
      <h1>{h1}</h1>
      <p>{intro}</p>
    </div>
  </section>

  <section class="section page-content">
    <div class="container content-grid">
      <article class="content-main">
        <section>
          <h2>Leistungen</h2>
          <ul>
            {services.map((entry) => <li>{entry}</li>)}
          </ul>
        </section>

        <section>
          <h2>Für wen</h2>
          <ul>
            {forWhom.map((entry) => <li>{entry}</li>)}
          </ul>
        </section>

        <section>
          <h2>Vorteile</h2>
          <ul>
            {advantages.map((entry) => <li>{entry}</li>)}
          </ul>
        </section>

        <section>
          <h2>Ablauf</h2>
          <ol>
            {process.map((entry) => <li>{entry}</li>)}
          </ol>
        </section>

        <section>
          <h2>Erfahrung und Vertrauen</h2>
          <p>
            Seit 2004 realisieren wir Sanierungsprojekte in Nordrhein-Westfalen.
            Tausende Kunden vertrauen auf unsere Arbeit.
          </p>
        </section>

        <section>
          <h2>Einsatzgebiet</h2>
          <p>Wir bieten diese Leistung in Nordrhein-Westfalen an, einschließlich:</p>
          <ul>
            {
              einsatzgebietCityLinks.map((city) => (
                <li>
                  <a href={city.href}>{city.name}</a>
                </li>
              ))
            }
          </ul>
          <p>
            <a href="/einsatzgebiet">Übersicht Einsatzgebiet</a>
          </p>
        </section>

        <RelatedServices currentMetaSlug={metaSlug} />

        <section>
          <h2>Jetzt Angebot anfordern</h2>
          <p>Schicken Sie uns kurz die Eckdaten zu Ihrem Projekt.</p>
          <a href="/kontakt" class="button button-primary">Jetzt Angebot anfordern</a>
        </section>
      </article>

      <aside class="content-aside">
        <h2>{ctaTitle}</h2>
        <p>{ctaText}</p>
        <a href="/kontakt" class="button button-primary">Jetzt Angebot anfordern</a>
      </aside>
    </div>
  </section>
</BaseLayout>
