---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import "../styles/global.css";

const {
  title = "HausFit NRW",
  description = "HausFit NRW ist Ihr Baupartner für Sanierung, Renovierung, Innenausbau und Modernisierung in Nordrhein-Westfalen.",
  noindex = false,
  googleSiteVerification = "PLACEHOLDER_VERIFICATION_CODE"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description}
    />
    <meta name="google-site-verification" content={googleSiteVerification} />
    <meta name="robots" content={noindex ? "noindex,follow" : "index,follow"} />
    <link rel="canonical" href={Astro.url.href} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
    <CookieConsent />
    <a
      href="https://wa.me/491799238814?text=Hallo%20ich%20interessiere%20mich%20für%20eine%20Sanierung"
      class="whatsapp-button"
      target="_blank"
      rel="noopener"
      aria-label="WhatsApp Kontakt"
    >
      WhatsApp
    </a>
  </body>
</html>
