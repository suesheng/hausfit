---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import "../styles/global.css";

const {
  title = "HausFit NRW",
  description = "HausFit NRW ist Ihr Baupartner für Sanierung, Renovierung, Innenausbau und Modernisierung in Nordrhein-Westfalen.",
  noindex = false,
  googleSiteVerification = "cposFC8Sr5tYiNdp4R0gv0BBIqstqpR3cL5LeWM43uE"
} = Astro.props;

const gaMeasurementId = "G-8235ZYX2TR";
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description}
    />
    <meta name="google-site-verification" content={googleSiteVerification} />
    <meta name="robots" content={noindex ? "noindex,follow" : "index,follow"} />
    <link rel="canonical" href={Astro.url.href} />
    <title>{title}</title>
    <script
      type="text/plain"
      data-cookie-category="analytics"
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
    ></script>
    <script type="text/plain" data-cookie-category="analytics" is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", "G-8235ZYX2TR", {
        anonymize_ip: true
      });
    </script>
    <slot name="head" />
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
    <CookieConsent />
    <a
      href="https://wa.me/491799238814?text=Hallo%20ich%20interessiere%20mich%20für%20eine%20Sanierung"
      class="whatsapp-button"
      target="_blank"
      rel="noopener"
      aria-label="WhatsApp Kontakt"
    >
      WhatsApp
    </a>
  </body>
</html>
