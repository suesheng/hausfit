---
import RatgeberArticle from "../../components/RatgeberArticle.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Was ist eine Blitzreparatur nach Installation?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Eine Blitzreparatur bedeutet die schnelle Wiederherstellung von Wänden, Fliesen und Oberflächen nach Sanitär-, Elektro- oder Heizungsarbeiten, damit Räume rasch wieder nutzbar sind."
      }
    },
    {
      "@type": "Question",
      name: "Arbeiten Sie auch am Wochenende?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja. Wir können kurzfristige Reparaturfenster auch am Wochenende organisieren, wenn das Projekt es erfordert."
      }
    }
  ]
};
---

<RatgeberArticle
  title="Blitzreparatur NRW 2026 | HausFit"
  description="Blitzreparatur nach Sanitär- und Installationsarbeiten in NRW: schnelle Wiederherstellung von Wänden und Fliesen – auch am Wochenende."
  breadcrumbLabel="Blitzreparatur"
  h1="Blitzreparatur nach Sanitär- und Installationsarbeiten"
  intro="Nach Leitungsarbeiten bleiben oft aufgestemmte Wände, beschädigte Fliesen und offene Putzflächen zurück. Wir schließen diese Stellen blitzschnell, sauber und koordiniert, damit Bad, Küche oder Technikraum schnell wieder einsatzbereit sind."
  asideTitle="Reparatur anfragen"
  asideText="Kurz beschreiben, was passiert ist – wir melden uns schnell zurück."
  faqSchema={faqSchema}
>
  <section>
    <h2>Wann ist eine Blitzreparatur sinnvoll?</h2>
    <ul>
      <li>Nach Sanitär- oder Heizungsinstallation mit Putz- und Fliesenschäden</li>
      <li>Bei undichten Anschlüssen mit Folgeschäden an Wänden</li>
      <li>Wenn Räume kurzfristig wieder nutzbar sein müssen</li>
    </ul>
  </section>

  <section>
    <h2>Leistungen</h2>
    <p>
      <a href="/leistungen/trockenbau-nrw">Trockenbau</a>,
      <a href="/leistungen/fliesenleger-nrw">Fliesenarbeiten</a> und
      <a href="/leistungen/malerarbeiten-nrw">Malerarbeiten</a> aus einer Hand.
      Mehr in den <a href="/faq">FAQ</a>.
    </p>
  </section>
</RatgeberArticle>
