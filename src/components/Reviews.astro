---
const {
  googleReviewsUrl = "https://www.google.com/search?q=HausFit+NRW+Bewertungen",
  trustpilotReviewsUrl = "https://www.trustpilot.com/review/hausfit.nrw"
} = Astro.props;
---

<section class="section reviews-section reviews-section-compact" aria-labelledby="reviews-title">
  <div class="container">
    <div class="section-heading reviews-heading">
      <p class="eyebrow">Kundenstimmen</p>
      <h2 id="reviews-title" class="desktop-only">Echte Bewertungen aus Google und Trustpilot</h2>
      <p class="desktop-only">Direkte Quellen statt statischer Zitate. Für Details öffnen Sie die Originalplattformen.</p>
    </div>

    <div class="reviews-live-grid desktop-only">
      <article class="review-source-card card">
        <div class="review-source-head">
          <h3>Google</h3>
          <span>Originalseite</span>
        </div>
        <p class="review-source-text">
          Lesen Sie aktuelle Kundenmeinungen direkt bei Google und verschaffen Sie sich einen transparenten Eindruck.
        </p>
        <a class="button button-primary" href={googleReviewsUrl} target="_blank" rel="noopener noreferrer">
          Google-Bewertungen öffnen
        </a>
      </article>

      <article class="review-source-card card">
        <div class="review-source-head">
          <h3>Trustpilot</h3>
          <span>Originalseite</span>
        </div>
        <p class="review-source-text">
          Sehen Sie alle verifizierten Trustpilot-Rezensionen auf der offiziellen Plattform.
        </p>
        <a class="button button-primary" href={trustpilotReviewsUrl} target="_blank" rel="noopener noreferrer">
          Trustpilot-Bewertungen öffnen
        </a>
      </article>
    </div>

    <div class="reviews-mobile-links mobile-only" aria-label="Bewertungen auf Originalplattformen">
      <a class="button button-primary" href={googleReviewsUrl} target="_blank" rel="noopener noreferrer">
        Google-Bewertungen auf Originalseite
      </a>
      <a class="button button-secondary" href={trustpilotReviewsUrl} target="_blank" rel="noopener noreferrer">
        Trustpilot-Bewertungen auf Originalseite
      </a>
    </div>
  </div>
</section>
