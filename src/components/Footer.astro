      <div>
        <a class="brand footer-brand" href="/" aria-label="HausFit NRW Startseite">
          <img src="/logo_dark.svg" alt="HausFit NRW" class="brand-logo" loading="lazy" />
        </a>
        <p class="footer-tagline">Zuverlässige Sanierung mit klarer Kommunikation.</p>
      </div>

      <div>
        <h2>Kontakt</h2>
        <ul class="footer-list">
          <li>
            Mülheimer Straße 16<br />
            40239 Düsseldorf
          </li>
          <li><a href="tel:+491799238814">+49 179 923 8814</a></li>
          <li><a href="mailto:info@hausfit.nrw">info@hausfit.nrw</a></li>
        </ul>
      </div>

      <div>
        <h2>Rechtliches</h2>
        <ul class="footer-list">
          <li><a href="/impressum">Impressum</a></li>
          <li><a href="/datenschutz">Datenschutz</a></li>
