---
import type { FaqEntry } from "../data/faq.js";

interface Props {
  items: FaqEntry[];
  accordionId?: string;
}

const { items, accordionId = "faqAccordion" } = Astro.props;

if (!items?.length) {
  throw new Error("FaqAccordion requires at least one FAQ item.");
}
---

<div class="accordion faq-accordion" id={accordionId}>
  {
    items.map((item, index) => {
      const headingId = `${item.id}-heading`;
      const collapseId = `${item.id}-collapse`;
      const isFirst = index === 0;
      return (
        <div class="accordion-item">
          <h3 class="accordion-header" id={headingId}>
            <button
              class:list={["accordion-button", { collapsed: !isFirst }]}
              type="button"
              data-bs-toggle="collapse"
              data-bs-target={`#${collapseId}`}
              aria-expanded={isFirst ? "true" : "false"}
              aria-controls={collapseId}
            >
              {item.question}
            </button>
          </h3>
          <div
            id={collapseId}
            class:list={["accordion-collapse", "collapse", { show: isFirst }]}
            aria-labelledby={headingId}
            data-bs-parent={`#${accordionId}`}
          >
            <div class="accordion-body" set:html={item.answerHtml} />
          </div>
        </div>
      );
    })
  }
</div>

<script is:inline define:vars={{ accordionId }}>
  (function () {
    const accordion = document.getElementById(accordionId);
    if (!accordion) return;

    const toggles = accordion.querySelectorAll('[data-bs-toggle="collapse"]');
    toggles.forEach((btn) => {
      btn.addEventListener("click", () => {
        const targetSelector = btn.getAttribute("data-bs-target");
        if (!targetSelector) return;
        const panel = accordion.querySelector(targetSelector);
        if (!panel) return;

        const isOpen = panel.classList.contains("show");
        accordion.querySelectorAll(".accordion-collapse.show").forEach((openPanel) => {
          openPanel.classList.remove("show");
        });
        accordion.querySelectorAll(".accordion-button").forEach((openBtn) => {
          openBtn.classList.add("collapsed");
          openBtn.setAttribute("aria-expanded", "false");
        });

        if (!isOpen) {
          panel.classList.add("show");
          btn.classList.remove("collapsed");
          btn.setAttribute("aria-expanded", "true");
        }
      });
    });
  })();
</script>
