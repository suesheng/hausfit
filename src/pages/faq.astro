---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import { getRootPageMeta } from "../data/page-meta.js";
import { renovationFaq } from "../data/faq.js";

const pageMeta = getRootPageMeta(Astro.url.pathname);
if (!pageMeta) throw new Error("Page meta not found for faq");

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: renovationFaq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.schemaAnswer
    }
  }))
};
---

<BaseLayout title={pageMeta.title} description={pageMeta.description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <section class="page-hero">
    <div class="container">
      <Breadcrumb
        items={[
          { label: "Startseite", url: "/" },
          { label: "FAQ", url: "/faq" }
        ]}
      />
      <p class="eyebrow">FAQ</p>
      <h1>Häufige Fragen zur Sanierung in NRW</h1>
      <p>
        Antworten zu Kosten, Förderungen 2026, Festpreisen, Ablauf und Einsatzgebiet –
        kompakt von HausFit NRW.
      </p>
    </div>
  </section>

  <section class="section page-content">
    <div class="container content-grid">
      <article class="content-main">
        <section>
          <h2>Fragen &amp; Antworten</h2>
          <p class="desktop-only">
            Klicken Sie auf eine Frage für die Antwort. Weiterführende Infos finden Sie
            in unseren Leistungsseiten.
          </p>

          <FaqAccordion items={renovationFaq} />
        </section>

        <section>
          <h2>Noch eine Frage?</h2>
          <p>
            Beschreiben Sie Ihr Vorhaben kurz – wir melden uns mit den nächsten Schritten.
          </p>
          <a href="/kontakt" class="button button-primary">Kostenloses Angebot anfragen</a>
        </section>
      </article>

      <aside class="content-aside">
        <h2>Leistungen</h2>
        <p>Sanierung und Innenausbau aus einer Hand:</p>
        <ul>
          <li><a href="/leistungen/badsanierung-nrw">Badsanierung</a></li>
          <li><a href="/leistungen/dachausbau-nrw">Dachausbau</a></li>
          <li><a href="/leistungen/fassadendaemmung-nrw">Fassadendämmung</a></li>
          <li><a href="/leistungen/generalunternehmer-nrw">Generalunternehmer</a></li>
          <li><a href="/leistungen">Alle Leistungen</a></li>
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>
