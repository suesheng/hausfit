---
import { getActivePromotion } from "../data/promotions.js";

interface Props {
  metaSlug: string;
  variant?: "ribbon" | "ribbon-contained" | "line" | "inline";
}

const { metaSlug, variant = "ribbon" } = Astro.props;
const promo = getActivePromotion(metaSlug);
---

{promo && variant === "ribbon" && <span class="promo-ribbon">-{promo.percent}%</span>}

{promo && variant === "ribbon-contained" && (
  <span class="promo-ribbon promo-ribbon--contained">-{promo.percent}%</span>
)}

{promo && variant === "line" && (
  <p class="promo-line">Aktion: {promo.percent}% Rabatt bis {promo.validUntilLabel}</p>
)}

{promo && variant === "inline" && (
  <p class="promo-banner">
    <span class="promo-pill promo-pill--inline">{promo.percent}% Rabatt</span>
    <span class="promo-banner-date">gültig bis {promo.validUntilLabel}</span>
  </p>
)}
