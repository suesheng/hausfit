---
import RatgeberArticle from "../../components/RatgeberArticle.astro";
import { dachausbauKostenRatgeber } from "../../data/ratgeber/dachausbau-kosten-planung-nrw.js";

const {
  title,
  description,
  breadcrumbLabel,
  h1,
  intro,
  sections,
  asideTitle,
  asideText,
  asideCtaLabel,
  faqSchema
} = dachausbauKostenRatgeber;
---

