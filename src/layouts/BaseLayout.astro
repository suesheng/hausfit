---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import "../styles/global.css";

const {
  title = "HausFit NRW",
  description = "HausFit NRW ist Ihr Baupartner für Sanierung, Renovierung, Innenausbau und Modernisierung in Nordrhein-Westfalen.",
  noindex = false,
  googleSiteVerification = "cposFC8Sr5tYiNdp4R0gv0BBIqstqpR3cL5LeWM43uE",
  socialImage = "/og-image.jpg"
} = Astro.props;

const gaMeasurementId = "G-8235ZYX2TR";
const googleAdsTagId = "AW-17925018117";
const canonicalUrl = Astro.url.href;
const socialImageUrl = new URL(socialImage, Astro.url).toString();
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description}
    />
    <meta name="google-site-verification" content={googleSiteVerification} />
    <meta name="robots" content={noindex ? "noindex,follow" : "index,follow"} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="HausFit NRW" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content="HausFit NRW - Sanierung und Innenausbau" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{title}</title>
    <script is:inline define:vars={{ gaMeasurementId, googleAdsTagId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
        functionality_storage: "granted",
        personalization_storage: "denied",
        security_storage: "granted",
        wait_for_update: 500
      });
      gtag("js", new Date());

      let gtagLibraryRequested = false;
      let analyticsConfigured = false;
      let adsConfigured = false;

      const ensureGtagLibrary = () => {
        if (gtagLibraryRequested) return;
        gtagLibraryRequested = true;
        const script = document.createElement("script");
        script.async = true;
        script.src = `https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`;
        document.head.appendChild(script);
      };

      const applyConsentConfig = (consent) => {
        if (!consent) return;
        if (consent.analytics || consent.marketing) ensureGtagLibrary();

        if (consent.analytics && !analyticsConfigured) {
          gtag("config", gaMeasurementId, { anonymize_ip: true });
          analyticsConfigured = true;
        }

        if (consent.marketing && !adsConfigured) {
          gtag("config", googleAdsTagId);
          adsConfigured = true;
        }
      };

      window.addEventListener("hausfit:cookie-consent-updated", (event) => {
        applyConsentConfig(event.detail);
      });

      try {
        const storedConsent = JSON.parse(localStorage.getItem("hausfit_cookie_consent_v1") || "null");
        applyConsentConfig(storedConsent);
      } catch {
        // no stored consent yet
      }
    </script>
    <slot name="head" />
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
    <CookieConsent />
    <a
      href="https://wa.me/491799238814?text=Hallo%20ich%20interessiere%20mich%20für%20eine%20Sanierung"
      class="whatsapp-button"
      target="_blank"
      rel="noopener"
      aria-label="WhatsApp Kontakt"
    >
      WhatsApp
    </a>
    <script is:inline>
      (() => {
        const track = (eventName, params = {}) => {
          if (typeof window.gtag !== "function") return;
          window.gtag("event", eventName, params);
        };

        document.addEventListener("click", (event) => {
          const anchor = event.target.closest("a[href]");
          if (!anchor) return;

          const href = (anchor.getAttribute("href") || "").trim();
          const location = anchor.closest("header")
            ? "header"
            : anchor.closest("footer")
              ? "footer"
              : anchor.closest(".cta-block")
                ? "cta"
                : anchor.closest(".contact-card")
                  ? "contact_card"
                  : "content";

          if (href.startsWith("tel:")) {
            track("generate_lead", {
              lead_type: "phone_click",
              contact_method: "phone",
              link_url: href,
              placement: location
            });
          }

          if (href.startsWith("mailto:")) {
            track("generate_lead", {
              lead_type: "email_click",
              contact_method: "email",
              link_url: href,
              placement: location
            });
          }

          if (href.includes("wa.me")) {
            track("generate_lead", {
              lead_type: "whatsapp_click",
              contact_method: "whatsapp",
              link_url: href,
              placement: location
            });
          }
        });

        document.addEventListener("submit", (event) => {
          const form = event.target;
          if (!(form instanceof HTMLFormElement)) return;
          if (form.id !== "whatsapp-form" && !form.classList.contains("whatsapp-form")) return;

          track("generate_lead", {
            lead_type: "contact_form_submit",
            contact_method: "whatsapp_form",
            placement: "contact_page"
          });
        });
      })();
    </script>
  </body>
</html>
