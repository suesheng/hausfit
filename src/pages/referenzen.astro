---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/projects/*.{webp,jpg,jpeg,png}",
  { eager: true }
);

const fallbackProjectImage = projectImages["/src/assets/images/projects/projekt.webp"]?.default;

const projects = [
  {
    imageSlug: "projekt1",
    alt: "Fertiges Bad nach Badsanierung in Düsseldorf",
    title: "Badsanierung Düsseldorf",
    text: "Vom alten Bad bis zur Abnahme: Abdichtung, neue Leitungen, Fliesen und Sanitär – abgestimmt auf Grundriss und Budget."
  },
  {
    imageSlug: "projekt2",
    alt: "Trockenbauwände und abgehängte Decke in Köln",
    title: "Trockenbau Köln",
    text: "Neue Raumstruktur mit Trennwänden und Deckenkonstruktion, inklusive Schnittstellen zu Elektro und Folgegewerken."
  },
  {
    imageSlug: "projekt3",
    alt: "Dachgeschoss vor und nach dem Ausbau in Essen",
    title: "Dachausbau Essen",
    text: "Rohdachraum zur Wohnfläche: Dämmung im Aufbau, neue Dachfenster, Estrich oder Bodenaufbau, Malerarbeiten und Beleuchtung – alles aus einem durchgängigen Ablauf."
  },
  {
    imageSlug: "projekt4",
    alt: "Fliesen in Bad und Küche nach Neuverlegung in Dortmund",
    title: "Fliesenarbeiten Dortmund",
    text: "Wand- und Bodenfliesen in Bad und Küche: Untergrund vorbereitet, präzise verlegt und fugensicher abgeschlossen."
  },
  {
    imageSlug: "projekt5",
    alt: "Schimmelsanierung und sanierte Wandflächen in Duisburg",
    title: "Schimmelbeseitigung Duisburg",
    text: "Befall sachgerecht entfernt, Feuchtequelle eingegrenzt, Trocknung und Wiederaufbau – mit dokumentierter Übergabe."
  }
];

const resolveProjectImage = (slug: string) =>
  projectImages[`/src/assets/images/projects/${slug}.webp`]?.default ??
  projectImages[`/src/assets/images/projects/${slug}.jpg`]?.default ??
  projectImages[`/src/assets/images/projects/${slug}.jpeg`]?.default ??
  projectImages[`/src/assets/images/projects/${slug}.png`]?.default ??
  fallbackProjectImage;
---

<BaseLayout title="Referenzen Sanierung NRW | HausFit NRW">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Referenzen</p>
      <h1>Referenzen</h1>
      <p>
        Ein kurzer Einblick in abgeschlossene Projekte in Nordrhein-Westfalen.
        Alle Leistungen wurden durch unser Team geplant und umgesetzt.
      </p>
    </div>
  </section>

  <section class="section page-content">
    <div class="container content-grid">
      <article class="content-main">
        <section>
          <h2>Ausgewählte Projekte</h2>
          <ul class="project-list">
            {
              projects.map((project) => (
                <li>
                  <Image src={resolveProjectImage(project.imageSlug)} alt={project.alt} width={800} quality={70} format="webp" loading="lazy" />
                  <strong>{project.title}</strong>
                  <span>{project.text}</span>
                </li>
              ))
            }
          </ul>
        </section>

        <section>
          <h2>Zielgruppe</h2>
          <p>
            Unsere Projekte entstehen für Eigentümer, Vermieter,
            Hausverwaltungen, Privatkunden und Gewerbekunden.
          </p>
        </section>

        <section>
          <h2>Vorteile</h2>
          <ul>
            <li>Erfahrung mit unterschiedlichen Objekten</li>
            <li>Saubere Arbeitsschritte</li>
            <li>Klare Kommunikation zum Projektstand</li>
            <li>Koordination mehrerer Gewerke</li>
          </ul>
        </section>

        <section>
          <h2>Ablauf</h2>
          <ol>
            <li>Sie beschreiben Ihr Projekt.</li>
            <li>Wir prüfen Umfang und passende Leistungen.</li>
            <li>Wir erstellen ein Angebot.</li>
            <li>Wir setzen die Arbeiten nach Absprache um.</li>
          </ol>
        </section>
      </article>

      <aside class="content-aside">
        <h2>Eigenes Projekt?</h2>
        <p>Sie möchten ein ähnliches Projekt umsetzen?</p>
        <a href="/kontakt" class="button button-primary">Angebot anfragen</a>
      </aside>
    </div>
  </section>
</BaseLayout>
