---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "./Breadcrumb.astro";

export interface RatgeberBlock {
  type: "p" | "h3" | "ul" | "ol" | "table";
  text?: string;
  items?: string[];
  table?: {
    headers: string[];
    rows: string[][];
  };
}

export interface RatgeberSection {
  heading: string;
  blocks: RatgeberBlock[];
}

interface Props {
  title: string;
  description: string;
  breadcrumbLabel: string;
  h1: string;
  intro: string;
  sections?: RatgeberSection[];
  asideTitle: string;
  asideText: string;
  asideCtaLabel?: string;
  asideCtaHref?: string;
  faqSchema?: Record<string, unknown>;
}

const {
  title,
  description,
  breadcrumbLabel,
  h1,
  intro,
  sections = [],
  asideTitle,
  asideText,
  asideCtaLabel = "Jetzt Anfrage senden",
  asideCtaHref = "/kontakt",
  faqSchema
} = Astro.props;

const hasSlotContent = Astro.slots.has("default");
---

<BaseLayout title={title} description={description}>
  {faqSchema && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <section class="page-hero">
    <div class="container">
      <Breadcrumb
        items={[
          { label: "Startseite", url: "/" },
          { label: "Ratgeber", url: "/ratgeber/" },
          { label: breadcrumbLabel, url: Astro.url.pathname }
        ]}
      />
      <p class="eyebrow">Ratgeber</p>
      <h1>{h1}</h1>
      <p>{intro}</p>
    </div>
  </section>

  <section class="section page-content">
    <div class="container content-grid">
      <article class="content-main ratgeber-article-body">
        {
          hasSlotContent ? (
            <slot />
          ) : (
            sections.map((section) => (
              <section>
                <h2>{section.heading}</h2>
                {section.blocks.map((block) => {
                  if (block.type === "h3" && block.text) {
                    return <h3 set:html={block.text} />;
                  }
                  if (block.type === "p" && block.text) {
                    return <p set:html={block.text} />;
                  }
                  if (block.type === "ul" && block.items) {
                    return (
                      <ul>
                        {block.items.map((item) => (
                          <li set:html={item} />
                        ))}
                      </ul>
                    );
                  }
                  if (block.type === "ol" && block.items) {
                    return (
                      <ol>
                        {block.items.map((item) => (
                          <li set:html={item} />
                        ))}
                      </ol>
                    );
                  }
                  if (block.type === "table" && block.table) {
                    return (
                      <div class="ratgeber-table-wrap">
                        <table class="ratgeber-table">
                          <thead>
                            <tr>
                              {block.table.headers.map((header) => (
                                <th>{header}</th>
                              ))}
                            </tr>
                          </thead>
                          <tbody>
                            {block.table.rows.map((row) => (
                              <tr>
                                {row.map((cell) => (
                                  <td set:html={cell} />
                                ))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    );
                  }
                  return null;
                })}
              </section>
            ))
          )
        }
      </article>

      <aside class="content-aside">
        <h2>{asideTitle}</h2>
        <p>{asideText}</p>
        <a href={asideCtaHref} class="button button-primary">{asideCtaLabel}</a>
      </aside>
    </div>
  </section>
</BaseLayout>
