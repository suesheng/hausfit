---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { serviceUrlBySlug } from "../data/services.js";

const serviceImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/services/*.{webp,jpg,png}",
  { eager: true }
);
const services = [
  { slug: "badsanierung", name: "Badsanierung", text: "Komplettsanierung von Badezimmern." },
  { slug: "trockenbau", name: "Trockenbau", text: "Neue Räume und Deckenlösungen." },
  { slug: "fliesenarbeiten", name: "Fliesenarbeiten", text: "Wand- und Bodenflächen präzise verlegt." },
  { slug: "bodenverlegung", name: "Bodenverlegung", text: "Vinyl, Laminat und Designböden." },
  { slug: "malerarbeiten", name: "Malerarbeiten", text: "Innenräume und Fassaden sauber gestrichen." },
  { slug: "dachausbau", name: "Dachausbau", text: "Dachraum ausbauen und nutzbar machen." },
  { slug: "schimmelbeseitigung", name: "Schimmelbeseitigung", text: "Ursachen klären und Flächen sanieren." },
  { slug: "asbestbeseitigung", name: "Asbestbeseitigung", text: "Rückbau nach geltenden Vorgaben." }
];
const defaultServiceImage = serviceImages["/src/assets/images/services/badsanierung.webp"]?.default;

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Leistungen von HausFit NRW",
  itemListElement: services.map((service, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: service.name,
    url: `https://www.hausfit.nrw${serviceUrlBySlug[service.slug] ?? `/leistungen/${service.slug}-nrw`}`
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Start",
      item: "https://www.hausfit.nrw/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Leistungen",
      item: "https://www.hausfit.nrw/leistungen"
    }
  ]
};
---

<BaseLayout title="Leistungen in NRW | HausFit NRW">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)}></script>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Leistungen</p>
      <h1>Unsere Leistungen für Sanierung und Ausbau</h1>
      <p>Hier finden Sie alle Hauptleistungen mit direktem Einstieg zur passenden Leistungsseite.</p>
    </div>
  </section>

  <section class="section page-content">
    <div class="container">
      <div class="section-heading">
        <h2>Leistungsübersicht</h2>
      </div>

      <div class="service-grid">
        {
          services.map((service) => (
            <article class="service-card card">
              <div class="service-image">
                <Image
                  src={serviceImages[`/src/assets/images/services/${service.slug}.webp`]?.default ?? defaultServiceImage}
                  alt={`${service.name} in NRW von HausFit`}
                  width={800}
                  quality={70}
                  format="webp"
                  loading="lazy"
                />
              </div>
              <h3>{service.name}</h3>
              <p>{service.text}</p>
              <a href={serviceUrlBySlug[service.slug] ?? `/leistungen/${service.slug}-nrw`}>Zur Leistungsseite</a>
            </article>
          ))
        }
      </div>

      <div class="section-heading" style="margin-top:48px;">
        <h2>Ratgeber zu Kosten und Planung</h2>
        <p class="desktop-only">Hilfreiche Einstiegsseiten für Budget, Ablauf und Entscheidung.</p>
      </div>

      <ul>
        <li><a href="/ratgeber/sanierung-kosten-duesseldorf">Sanierung Kosten Düsseldorf</a></li>
        <li><a href="/ratgeber/badsanierung-preise-nrw">Badsanierung Preise NRW</a></li>
        <li><a href="/ratgeber/trockenbau-kosten-nrw">Trockenbau Kosten NRW</a></li>
        <li><a href="/ratgeber/blitzreparatur-nach-installation-nrw">Blitzreparatur nach Installation</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>
