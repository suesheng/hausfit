---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ServiceSchema from "../components/ServiceSchema.astro";
import { cities } from "../data/cities.js";
import { serviceCombos } from "../data/services.js";
import { getComboPageMeta } from "../data/page-meta.js";

export function getStaticPaths() {
  const paths = [];

  for (const serviceKey in serviceCombos) {
    for (const cityKey in cities) {
      paths.push({
        params: {
          service: serviceKey,
          city: cityKey
        }
      });
    }
  }

  return paths;
}

const { service, city } = Astro.params;

const serviceData = service ? serviceCombos[service as keyof typeof serviceCombos] : undefined;
const cityData = city ? cities[city as keyof typeof cities] : undefined;

if (!serviceData || !cityData) {
  throw new Error("Ungültige Service- oder Stadtkombination.");
}

const cityUrl = `/einsatzgebiet/${city}`;
const pageMeta = getComboPageMeta(service, city);
const pageTitle = pageMeta.title;
const pageDescription = pageMeta.description;

const intro = `${serviceData.name} in ${cityData.name}. ${serviceData.description} Klare Planung. Saubere Umsetzung.`;

const vorteile = [
  "Fester Ansprechpartner",
  "Klare Preise",
  "Schnelle Umsetzung"
];

const ablauf = ["Anfrage", "Besichtigung", "Angebot", "Umsetzung"];

const comboPath = Astro.url.pathname;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <ServiceSchema
    slot="head"
    serviceName={serviceData.name}
    serviceSlug={service!}
    description={pageDescription}
    city={cityData.name}
  />
  <section class="page-hero">
    <div class="container">
      <Breadcrumb
        items={[
          { label: "Startseite", url: "/" },
          { label: "Leistungen", url: "/leistungen" },
          { label: serviceData.name, url: serviceData.nrwUrl },
          { label: cityData.name, url: comboPath }
        ]}
      />
      <p class="eyebrow">Leistung in Ihrer Stadt</p>
      <h1>{serviceData.name} in {cityData.name}</h1>
      <p>{intro}</p>
    </div>
  </section>

  <section class="section page-content">
    <div class="container content-grid">
      <article class="content-main">
        <section>
          <h2>Leistungen</h2>
          <ul>
            {serviceData.leistungen.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section>
          <h2>Vorteile</h2>
          <ul>
            {vorteile.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section>
          <h2>Ablauf</h2>
          <ol>
            {ablauf.map((item) => <li>{item}</li>)}
          </ol>
        </section>

        <section>
          <h2>Weitere Informationen</h2>
          <p>
            Diese Seite ist die Hauptquelle für „{serviceData.name} in {cityData.name}“. Für
            allgemeine Sanierung in {cityData.name} oder den NRW-Überblick zur Leistung:
          </p>
          <ul>
            <li>
              <a href={serviceData.nrwUrl}>{serviceData.name} in ganz NRW</a>
              <span> – Leistungsübersicht NRW</span>
            </li>
            <li>
              <a href={cityUrl}>Sanierung in {cityData.name}</a>
              <span> – alle Gewerke am Standort</span>
            </li>
          </ul>
        </section>

        <section>
          <h2>Jetzt Angebot anfordern</h2>
          <p>Senden Sie uns die Eckdaten zu Ihrem Projekt in {cityData.name}.</p>
          <a href="/kontakt" class="button button-primary">Jetzt Angebot anfordern</a>
        </section>
      </article>

      <aside class="content-aside">
        <h2>Projekt in {cityData.name}</h2>
        <p>Wir melden uns zeitnah mit dem nächsten Schritt.</p>
        <a href="/kontakt" class="button button-primary">Jetzt Anfrage senden</a>
      </aside>
    </div>
  </section>
</BaseLayout>
