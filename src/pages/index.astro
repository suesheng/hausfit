---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import Locations from "../components/Locations.astro";
import Process from "../components/Process.astro";
import CTA from "../components/CTA.astro";
import glebGranovskyPhoto from "../assets/images/owner/gleb-granovsky.png";
---

<BaseLayout title="HausFit NRW | Sanierung und Ausbau in NRW">
  <Hero />
  <Services />
  <Locations />
  <Process />
  <section class="owner-block section">
    <div class="container owner-grid">
      <div class="owner-image">
        <Image
          src={glebGranovskyPhoto}
          alt="Gleb Granovsky"
          width={800}
          format="webp"
          loading="lazy"
        />
      </div>

      <div class="owner-content">
        <h2>Persönliche Worte vom Inhaber</h2>
        <p>
          Mein Name ist Gleb Granovsky.
          Seit 2004 arbeite ich im Bereich Sanierung und Innenausbau.
        </p>
        <p>
          Mir ist wichtig, dass jedes Projekt sauber, zuverlässig und ohne Stress für den Kunden umgesetzt wird.
        </p>
        <p>
          Tausende Kunden haben uns bereits ihr Vertrauen geschenkt.
          Und genau dieses Vertrauen möchte ich mir auch bei Ihrem Projekt verdienen.
        </p>

        <div class="owner-signature">
          <strong>Gleb Granovsky</strong><br />
          <span>Inhaber HausFit NRW</span>
        </div>
      </div>
    </div>
  </section>
  <CTA />
</BaseLayout>